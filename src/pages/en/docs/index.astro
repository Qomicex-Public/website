---
import Base from '../../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { t, langFromPath } from '../../../i18n';

const lang = langFromPath(Astro.url.pathname)
const allDocs = (await getCollection('docs'))
  .filter(d => d.id.startsWith('en/'))
  .map(d => ({ ...d, id: d.id.replace(/^en\//, '') }))
  .sort((a, b) => a.data.order - b.data.order)

const groups = Object.entries(
  allDocs.reduce((acc, d) => {
    ;(acc[d.data.category] ??= []).push({ id: d.id, title: d.data.title })
    return acc
  }, {} as Record<string, { id: string; title: string }[]>),
)
---

<Base title={t('docs.title', lang)} desc={t('docs.description', lang)}>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-2 text-3xl font-bold">{t('docs.title', lang)}</h1>
    <p class="mb-10 text-muted-foreground">{t('docs.description', lang)}</p>
    <div class="space-y-8">
      {groups.map(([cat, items]) => (
        <div>
          <h2 class="mb-3 text-lg font-semibold">{cat}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {items.map(item => (
              <a href={`/en/docs/${item.id}/`} class="group rounded-xl border border-border bg-card p-5 transition-all hover:border-primary/30 hover:shadow-[0_0_16px_-8px_hsl(var(--primary)/0.25)]">
                <h3 class="mb-1 font-medium group-hover:text-primary">{item.title}</h3>
                <p class="text-xs text-muted-foreground">{t('docs.viewTutorial', lang)}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>

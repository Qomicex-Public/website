---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

const SERVICES = [
  { name: 'Modrinth', desc: 'Mod 和资源搜索 API', url: 'https://modrinth.com' },
  { name: 'CurseForge', desc: 'Mod 和资源搜索 API', url: 'https://www.curseforge.com' },
  { name: 'FTB', desc: '整合包 API', url: 'https://www.feed-the-beast.com' },
  { name: 'bangbang93', desc: '提供 BMCLAPI 下载镜像服务', url: 'https://bmclapi2.bangbang93.com' },
  { name: 'mcmod', desc: '中文 Mod 数据库', url: 'https://www.mcmod.cn' },
  { name: 'Minecraft 官网', desc: 'Minecraft 官方网站', url: 'https://www.minecraft.net' },
]

const REFERENCES = [
  { name: 'HMCL', url: 'https://github.com/HMCL-dev/HMCL/tree/main', desc: '版本检测参考' },
  { name: 'ProjBobcat', url: 'https://github.com/Corona-Studio/ProjBobcat', desc: 'ModLoader 安装器参考' },
  { name: 'PCL', url: 'https://github.com/Meloong-Git/PCL', desc: '启动流程参考' },
]
---

<Base title="关于">
  <section data-animate class="mx-auto max-w-3xl px-4 py-16">
    <!-- App Info -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <div class="flex items-center gap-4">
        <img src="/logo.svg" alt="Qomicex Launcher" class="h-14 w-14 rounded-2xl" />
        <div class="min-w-0 flex-1">
          <div class="text-lg font-semibold">Qomicex Launcher</div>
          <div id="about-version" class="text-sm text-muted-foreground">版本 ...</div>
        </div>
        <a href="https://github.com/Qomicex-Public/Qomicex.Tauri" target="_blank" class="inline-flex h-7 items-center gap-1.5 rounded-md px-2.5 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground">
          <Icon name="fa6-brands:github" class="size-3" />查看仓库
        </a>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">一个现代化的 Minecraft 启动器，拥有完善的多实例管理、快捷的模组安装、账户管理、多人联机、个性化主题设置等功能。完全开源，使用 GPL-3.0 许可协议。</p>
    </div>

    <!-- Version Info -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">版本信息</h2>
      <div class="rounded-lg bg-background p-4 text-sm">
        <div id="version-grid" class="grid grid-cols-2 gap-3">
          <div><div class="text-xs text-muted-foreground">应用版本</div><div class="mt-0.5 font-medium">...</div></div>
          <div><div class="text-xs text-muted-foreground">许可协议</div><div class="mt-0.5 font-medium"><a href="https://www.gnu.org/licenses/gpl-3.0.en.html" target="_blank" class="text-primary underline underline-offset-2">GPL-3.0</a></div></div>
        </div>
      </div>
    </div>

    <!-- Contributors -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">开发者</h2>
      <div id="contributors-list" class="space-y-3">
        <p class="text-sm text-muted-foreground">加载中...</p>
      </div>
    </div>

    <!-- Services -->
    <div class="mb-4 rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">所用服务</h2>
      <div class="space-y-2">
        {SERVICES.map(s => (
          <a href={s.url} target="_blank" class="flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors hover:bg-accent">
            <span class="font-medium">{s.name}</span>
            <span class="text-muted-foreground">{s.desc}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- References -->
    <div class="rounded-xl border border-border bg-card p-6">
      <h2 class="mb-3 text-base font-semibold">参考项目</h2>
      <div class="space-y-2">
        {REFERENCES.map(r => (
          <a href={r.url} target="_blank" class="flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors hover:bg-accent">
            <span class="font-medium">{r.name}</span>
            <span class="text-muted-foreground">{r.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
import { getReleases } from '../lib/releases.ts'
import { fetchContributors } from '../lib/contributors.ts'

getReleases().then(function (releases) {
  var stable = releases.find(function (r) { return !r.prerelease })
  var pre = releases.find(function (r) { return r.prerelease })
  var versionEl = document.getElementById('about-version')
  var grid = document.getElementById('version-grid')

  if (pre) {
    versionEl.textContent = '版本 ' + pre.version + (pre.prerelease ? ' (测试版)' : '')
  } else if (stable) {
    versionEl.textContent = '版本 ' + stable.version
  }

  if (grid) {
    var html = ''
    if (stable) {
      html += '<div><div class="text-xs text-muted-foreground">正式版</div><div class="mt-0.5 font-medium">' + stable.version + '</div></div>'
    }
    if (pre) {
      html += '<div><div class="text-xs text-muted-foreground">测试版</div><div class="mt-0.5 font-medium">' + pre.version + '</div></div>'
    }
    if (!stable && !pre) {
      html += '<div><div class="text-xs text-muted-foreground">应用版本</div><div class="mt-0.5 font-medium">获取失败</div></div>'
    }
    html += '<div><div class="text-xs text-muted-foreground">许可协议</div><div class="mt-0.5 font-medium"><a href="https://www.gnu.org/licenses/gpl-3.0.en.html" target="_blank" class="text-primary underline underline-offset-2">GPL-3.0</a></div></div>'
    grid.innerHTML = html
  }
})

fetchContributors().then(function (contributors) {
  var list = document.getElementById('contributors-list')
  if (contributors.length === 0) {
    list.innerHTML = '<p class="text-sm text-muted-foreground">获取贡献者信息失败。</p>'
    return
  }
  list.innerHTML = ''
  contributors.forEach(function (c) {
    var el = document.createElement('div')
    el.className = 'flex items-center gap-3'
    el.innerHTML = '<img src="' + c.avatar_url + '" alt="' + c.login + '" class="size-10 rounded-full object-cover" />'
      + '<div class="min-w-0 flex-1">'
      + '<div class="text-sm font-medium">' + c.login + '</div>'
      + '<div class="text-xs text-muted-foreground">' + c.contributions + ' 次提交</div>'
      + '</div>'
      + '<a href="' + c.html_url + '" target="_blank" class="inline-flex h-7 items-center gap-1.5 rounded-md px-2.5 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground">'
      + 'GitHub</a>'
    list.appendChild(el)
  })
})
</script>

---
import { getReleases } from '../lib/releases.ts';

const { platform, label = '下载' } = Astro.props as {
  platform: string;
  label?: string;
};
const releases = await getReleases()
const stable = releases.find(r => !r.prerelease)
const tag = stable ? `v${stable.version}` : (releases[0] ? `v${releases[0].version}` : 'latest')
const downloadUrl = `https://github.com/Qomicex-Public/Qomicex.Tauri/releases/${tag}`
const isPre = releases[0]?.prerelease
---

<a
  href={downloadUrl}
  class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-[var(--color-bg)] transition-colors hover:bg-[var(--color-primary-hover)]"
  target="_blank"
>
  <span>{label}</span>
  {platform && <span class="text-xs opacity-70">({platform})</span>}
</a>
